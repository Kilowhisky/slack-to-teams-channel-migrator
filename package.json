{
  "name": "slack-to-teams-channel-migrator",
  "version": "1.0.0",
  "description": "CLI tool to migrate messages from a Slack channel to a Microsoft Teams channel",
  "main": "dist/index.js",
  "bin": {
    "slack-to-teams": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "slack",
    "teams",
    "migration",
    "microsoft-teams",
    "channel-migration"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@azure/identity": "^4.6.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@slack/web-api": "^7.8.0",
    "bottleneck": "^2.19.5",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
